hist(dataIMPACTsorted$DUPLEX_VAF, breaks = 100)
duplex_vaf_thres<-quantile(dataIMPACTsorted$DUPLEX_VAF, probs=seq(0, 1, 0.1))["0%"]
duplex_vaf_thres
