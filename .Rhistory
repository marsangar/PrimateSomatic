### Metadata for Primate Species
dataPRIM<-read.xlsx("01_metadata/Primate_Species_Features.xlsx") # Source: Miquel Llorente Espino [IUCN (2018); Zimmermann y Radespiel (2013); Kappeler y Pereira (2003)
dataPRIM
dataPRIM_sorted<-dataPRIM %>%
mutate(Family=factor(Family, levels = unique(Family)), Genus=factor(Genus, levels = unique(Genus)), Species=paste0(substring(dataPRIM$Family,1,1), ".", dataPRIM$SP), Body_mass=as.numeric(dataPRIM$Body_mass), Lifespan_max=as.numeric(dataPRIM$Lifespan_max)) %>%
arrange(Lifespan_max) %>%
mutate(Species=factor(Species, levels = unique(Species)))
dataPRIM_sorted
### Plot max lifespan
p_dataPRIM_sorted_lifespan<-ggplot(dataPRIM_sorted, aes(x = reorder(Family, Lifespan_max, median), y = Lifespan_max, fill = Family)) +
geom_point(size = 4, position = position_jitter(width = 0.15), alpha = 0.8, pch=21) +
labs(
title = "Maximum Lifespan Across Diverse Primate Species",
subtitle = "Source data: Llorente (2019), Zimmermann & Radespiel (2013), Kappeler & Pereira (2003), UICN.",
x = "Family",
y = "Maximum Lifespan (years)",
color = "Family"
) +
theme(plot.title = element_text(size=20)) +
scale_y_continuous(name="Maximum Lifespan (years)", limits=c(0, 125), breaks=seq(0,125,10)) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
p_dataPRIM_sorted_lifespan
p_dataPRIM_sorted_lifespan
